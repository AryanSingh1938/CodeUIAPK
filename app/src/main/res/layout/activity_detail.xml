<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:background="@drawable/detail_bg"
    tools:context=".DetailActivity">

    <ImageView
        android:id="@+id/image"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="62dp"
        android:adjustViewBounds="true"
        android:contentDescription="Mercury"
        android:scaleType="centerCrop"
        android:src="@drawable/mercury" />

    <TextView
        android:id="@+id/title"
        android:layout_marginTop="12dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_width="wrap_content"
        android:textColor="#FFFFFF"
        android:shadowColor="#FF00FF"
        android:shadowRadius="8"
        android:layout_height="wrap_content"
        android:fontFamily="@font/orbitronbold"
        android:text="Title"
        android:textSize="35sp"/>

    <TextView
        android:id="@+id/description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="28dp"
        android:textColor="#E0E0E0"
        android:fontFamily="@font/poppins_bold"
        android:text="Description"
        android:textSize="25sp" />
    <TextView
        android:id="@+id/distancefromsun"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:textColor="#B0BEC5"
        android:fontFamily="@font/poppins_bold"
        android:text="Distancefromsun"
        android:textSize="18sp"/>
    <TextView
        android:id="@+id/diameter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#B0BEC5"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Diameter"
        android:textSize="18sp"/>
    <TextView
        android:id="@+id/gravity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#B0BEC5"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Gravity"
        android:textSize="18sp"/>
    <TextView
        android:id="@+id/dayLength"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#B0BEC5"
        android:layout_gravity="center"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/poppins_bold"
        android:text="DayLength"
        android:textSize="18sp"/>
    <TextView
        android:id="@+id/yearLength"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#B0BEC5"
        android:layout_gravity="center"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/poppins_bold"
        android:text="YearLength"
        android:textSize="18sp"/>
    <TextView
        android:id="@+id/moons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#B0BEC5"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Moons"
        android:textSize="18sp"/>



</LinearLayout>